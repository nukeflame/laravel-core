{
  "name": "nukeflame/laravel-core",
  "description": "Core utilities and shared services for Laravel applications",
  "type": "library",
  "license": "MIT",
  "authors": [
    {
      "name": "nukeflame"
    }
  ],
  "autoload": {
    "psr-4": {
      "Nukeflame\\LaravelCore\\": "src/"
    }
  },
  "require": {
    "php": "^8.1",
    "illuminate/support": "^10.0|^11.0|^12.0"
  },
  "require-dev": {
    "phpunit/phpunit": "^11.0"
  },
  "extra": {
    "laravel": {
      "providers": [
        "Nukeflame\\LaravelCore\\CoreServiceProvider"
      ]
    }
  },
  "minimum-stability": "stable",
  "prefer-stable": true
}
